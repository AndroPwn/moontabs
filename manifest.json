{
  "manifest_version": 2,
  "name": "Moontabs",
  "version": "1.0.1",
  "description": "Tabs that sleep. Learns your patterns and protects the ones you always come back to.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "sessions"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "moontabs@user",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
